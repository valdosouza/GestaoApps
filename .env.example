# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real values to version control

# ===== APP CONFIGURATION =====
APP_NAME=BudgetSalesApp
APP_VERSION=1.0.0
ENVIRONMENT=development

# ===== API CONFIGURATION =====
# Base URL for API calls
API_BASE_URL=https://api.example.com
API_TIMEOUT=30

# ===== AUTHENTICATION =====
# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# OAuth Configuration
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URL=http://localhost:8080/callback

# ===== DATABASE =====
# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=budget_sales_db
DB_USER=dev_user
DB_PASSWORD=dev_password

# ===== KEYS AND TOKENS =====
# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY=3600

# API Keys
GOOGLE_API_KEY=your-google-api-key
MAPBOX_API_KEY=your-mapbox-api-key

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ===== FEATURE FLAGS =====
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_OFFLINE_MODE=true

# ===== SECURITY =====
ENCRYPTION_KEY=your-encryption-key
SSL_VERIFY=true

# Notes:
# - This file is a template and should never be committed with real values
# - Create a .env file in the root directory with your actual configuration
# - Use .env.local for machine-specific overrides
# - Use .env.production.local for production credentials (if needed)
